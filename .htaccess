Options -Indexes
RewriteEngine On
RewriteBase /web/fournier_roux/

RewriteRule "(^|/)\." - [F,L]

<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package(-lock)?\.json|README\.md|phpunit\.xml)$">
Require all denied
</FilesMatch>

<FilesMatch "\.(log|sql|bak|old|orig|save|swp)$">
Require all denied
</FilesMatch>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
