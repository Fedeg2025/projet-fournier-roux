Options -Indexes
RewriteEngine On
RewriteBase /web/fournier_roux/

# Bloque l’accès aux fichiers cachés
RewriteRule "(^|/)\." - [F,L]

# Bloque les fichiers sensibles
<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package(-lock)?\.json|README\.md|phpunit\.xml)$">
    Require all denied
</FilesMatch>

# Bloque les fichiers de logs, sauvegardes ou temporaires
<FilesMatch "\.(log|sql|bak|old|orig|save|swp)$">
    Require all denied
</FilesMatch>

# Redirige toutes les requêtes vers index.php si le fichier ou dossier n’existe pas
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]